# Copy this file to `.env` and fill in your values. Never commit `.env` itself
# (it's already in .gitignore).

# Required for broker/bandar data. Use the public-facing variable name below.
BROKER_API_TOKEN="Bearer replace_with_your_token"

# Optional: override the default watchlist (comma-separated, no .JK suffix).
# If unset, the small default list in src/idx_bandarmology/config.py is used.
WATCHLIST=BBCA,BBRI,BMRI,BBNI,TLKM,ASII,UNVR,GOTO,BREN,ANTM,BULL
