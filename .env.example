# Copy this file to `.env` and fill in your values. Never commit `.env` itself
# (it's already in .gitignore).

# Required for broker/bandar data (Stockbit). Get this from your browser's
# devtools -> Network tab -> any exodus.stockbit.com request -> Authorization
# header, after logging in to stockbit.com. Without this, the pipeline still
# works for prices (yfinance) but skips broker/bandar sections.
STOCKBIT_TOKEN=

# Optional: override the default watchlist (comma-separated, no .JK suffix).
# If unset, the small default list in src/idx_bandarmology/config.py is used.
WATCHLIST=BBCA,BBRI,BMRI,BBNI,TLKM,ASII,UNVR,GOTO,BREN,ANTM
